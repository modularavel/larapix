{
    "name": "modularavel/larapix",
    "description": "Gerar QRCODE e chave copia e cola com valor definido para pagamentos via PIX!",
    "keywords": [
        "modularavel",
        "laravel",
        "larapix",
        "pix",
        "qrcode",
        "pagamentos",
        "pagamentos pix",
        "pix php",
        "pix qrcode",
        "bacen",
        "copia e cola"
    ],
    "version": "1.2.0",
    "homepage": "https://github.com/modularavel/larapix",
    "license": "MIT",
    "authors": [
        {
            "name": "Casimiro Rocha",
            "email": "casimiroaf@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "mpdf/qrcode": "^1.2",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^2.9",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^7.0|^8.0",
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-arch": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-phpunit": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Modularavel\\Larapix\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modularavel\\Larapix\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modularavel\\Larapix\\LarapixServiceProvider"
            ],
            "aliases": {
                "Larapix": "Modularavel\\Larapix\\Facades\\Larapix"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
